# Camera
CAMERA_NAME=Imou-FrontDoor
RTSP_URL=rtsp://user:pass@192.168.1.10:554/cam/realmonitor?channel=1&subtype=0

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Detection
PERSON_MODEL=yolov8n.pt
FIRE_SMOKE_MODEL=
FIRE_LABELS=fire,smoke
PERSON_CONF=0.55
FIRE_SMOKE_CONF=0.45
CONSECUTIVE_FRAMES=3
ALERT_COOLDOWN_SECONDS=60
FRAME_SKIP=2
SNAPSHOT_DIR=./snapshots

# Optional hours (24h): only alert person outside office hours
OFFICE_HOUR_START=8
OFFICE_HOUR_END=18
ALERT_PERSON_OUTSIDE_OFFICE_HOURS=false
